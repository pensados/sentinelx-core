[Unit]
Description=SentinelX Core
After=network.target

[Service]
User=sentinelx
Group=sentinelx
WorkingDirectory=/opt/sentinelx
EnvironmentFile=/etc/sentinelx/sentinelx.env
ExecStart=/opt/sentinelx/venv/bin/uvicorn agent:app --host 127.0.0.1 --port ${AGENT_PORT:-8091}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
